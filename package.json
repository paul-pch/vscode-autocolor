{
  "name": "autocolor",
  "displayName": "AutoColor",
  "description": "Differentiate VS Code windows with a specific color",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "icon": "images/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/paul-pch/vscode-autocolor"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "publisher": "paul-pch",
  "contributes": {},
