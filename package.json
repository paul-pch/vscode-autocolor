{
  "name": "autocolor",
  "displayName": "AutoColor",
  "description": "Differentiate VS Code windows with a specific color",
  "version": "0.5.0",
  "engines": {
    "vscode": "^1.115.0",
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "icon": "images/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/paul-pch/vscode-autocolor"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "publisher": "paul-pch",
  "contributes": {},
  "license": "MIT",
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package --out extension.vsix",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc -watch -p ./"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.10",
    "typescript": "^6.0.2"
  }
}
